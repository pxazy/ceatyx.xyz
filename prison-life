local function EvaluateColor(mode, c1, c2, speed)
    if mode == 'Rainbow' then
        return Color3.fromHSV((tick() * speed) % 1, 1, 1)
    elseif mode == 'Gradient' then
        local alpha = (math.sin(tick() * speed) + 1) / 2
        return c1:Lerp(c2, alpha)
    end
    return c1
end

