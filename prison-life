local function MakeDraggable(mainObject)
    local UserInputService = game:GetService("UserInputService")
    local dragging = false
    local dragStart = nil
    local startPos = nil

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = UserInputService:GetMouseLocation()
            if mousePos.X >= mainObject.Position.X and mousePos.X <= mainObject.Position.X + mainObject.Size.X and
               mousePos.Y >= mainObject.Position.Y and mousePos.Y <= mainObject.Position.Y + mainObject.Size.Y then
                dragging = true
                dragStart = input.Position
                startPos = mainObject.Position
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            watermarkPosition = startPos + Vector2.new(delta.X, delta.Y)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

MakeDraggable(WatermarkBack)

local lastTime = 0
local fpsCount = 0
local fps = 0

local function UpdateWatermarkUI()
    fpsCount = fpsCount + 1
    if tick() - lastTime >= 1 then
        fps = fpsCount
        fpsCount = 0
        lastTime = tick()
    end

    local Time = os.date("%H:%M:%S")
    local PlayerName = game:GetService("Players").LocalPlayer.Name
    local textContent = string.format("cetyx.xyz | %s | %d fps | %s", PlayerName, fps, Time)
    
    WatermarkText.Text = textContent
    local textBounds = WatermarkText.TextBounds
    watermarkSize = Vector2.new(textBounds.X + 12, 22)

    WatermarkBack.Position = watermarkPosition
    WatermarkBack.Size = watermarkSize

    WatermarkOutline.Position = watermarkPosition - Vector2.new(1, 1)
    WatermarkOutline.Size = watermarkSize + Vector2.new(2, 2)

    WatermarkGradient.Position = watermarkPosition
    WatermarkGradient.Size = Vector2.new(watermarkSize.X, 1)

    WatermarkText.Position = watermarkPosition + Vector2.new(6, 4)
end

