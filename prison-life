local function GetRainbowColor()
    return Color3.fromHSV(tick() % 5 / 5, 1, 1)
end

local function GetRoleInfo(player)
    local team = player.Team and player.Team.Name or "Neutral"
    if team == "Guards" then return "Guard", Color3.fromRGB(0, 0, 255)
    elseif team == "Inmates" then return "Inmate", Color3.fromRGB(255, 165, 0)
    elseif team == "Criminals" then return "Criminal", Color3.fromRGB(255, 0, 0)
    else return "Neutral", Color3.fromRGB(255, 255, 255) end
end

local function IsVisible(part, character)
    if not Toggles.WallCheck.Value then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local result = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000, params)
    return result and result.Instance:IsDescendantOf(character)
end

local function GetClosestPlayer()
    local target = nil
    local shortestDist = Options.FovRadius.Value
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local part = char and char:FindFirstChild(Options.AimPart.Value == "Head" and "Head" or "UpperTorso")
        
        if part and hum and hum.Health > 0 then
            local role, _ = GetRoleInfo(player)
            local isFriend = LocalPlayer:IsFriendsWith(player.UserId)
            
            local skip = false
            if Toggles.AimIgnoreFriends.Value and isFriend then skip = true end
            if Toggles.AimIgnoreGuards.Value and role == "Guard" then skip = true end
            if Toggles.AimIgnoreInmates.Value and role == "Inmate" then skip = true end
            if Toggles.AimIgnoreCriminals.Value and role == "Criminal" then skip = true end
            if Toggles.AimIgnoreNeutral.Value and role == "Neutral" then skip = true end
            
            if not skip then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if mag < shortestDist and IsVisible(part, char) then
                        shortestDist = mag
                        target = part
                    end
                end
            end
        end
    end
    return target
end

local function CreateESP(Player)
    local Box = Drawing.new('Square')
    Box.Visible = false
    Box.Thickness = 1
    Box.Transparency = 1
    Box.Filled = false
    local Name = Drawing.new('Text')
    Name.Visible = false
    Name.Size = 14
    Name.Center = true
    Name.Outline = true
    local Health = Drawing.new('Text')
    Health.Visible = false
    Health.Size = 14
    Health.Center = true
    Health.Outline = true
    local FriendLabel = Drawing.new('Text')
    FriendLabel.Visible = false
    FriendLabel.Text = 'Friend'
    FriendLabel.Color = Color3.fromRGB(0, 255, 0)
    FriendLabel.Size = 14
    FriendLabel.Center = true
    FriendLabel.Outline = true
    local RoleLabel = Drawing.new('Text')
    RoleLabel.Visible = false
    RoleLabel.Size = 14
    RoleLabel.Center = true
    RoleLabel.Outline = true
    local Highlight = Instance.new("Highlight")
    Highlight.Enabled = false
    Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    ESP[Player] = {Box = Box, Name = Name, Health = Health, FriendLabel = FriendLabel, RoleLabel = RoleLabel, Highlight = Highlight}
end

for _, player in ipairs(Players:GetPlayers()) do if player ~= LocalPlayer then CreateESP(player) end end
Players.PlayerAdded:Connect(function(player) if player ~= LocalPlayer then CreateESP(player) end end)
Players.PlayerRemoving:Connect(function(player)
    if ESP[player] then
        for _, d in pairs(ESP[player]) do if typeof(d) == "Instance" then d:Destroy() else d:Remove() end end
        ESP[player] = nil
    end
end)

local lastHealth = {}

RunService.RenderStepped:Connect(function()
    local rainbow = GetRainbowColor()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    FovCircle.Visible = Toggles.ShowFov.Value
    FovCircle.Radius = Options.FovRadius.Value
    FovCircle.Position = center
    FovCircle.Color = Toggles.FovRainbow.Value and rainbow or Options.FovColor.Value

    if Toggles.AimEnabled.Value then
        local target = GetClosestPlayer()
        if target then
            local aimSmoothness = Options.AimSmooth.Value
            local lookAt = CFrame.new(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, 1 / aimSmoothness)
            
            if Toggles.AutoShoot.Value then
                mouse1press()
                task.wait()
                mouse1release()
            end
        end
    end

    if Toggles.SelfChams.Value and LocalPlayer.Character then
        SelfHighlight.Parent = LocalPlayer.Character
        SelfHighlight.Enabled = true
        local sColor = Toggles.SelfChamsRainbow.Value and rainbow or Options.SelfChamsColor.Value
        SelfHighlight.FillColor = sColor
        SelfHighlight.OutlineColor = sColor
    else
        SelfHighlight.Enabled = false
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local hum = player.Character and player.Character:FindFirstChild("Humanoid")
        if hum then
            if lastHealth[player] and hum.Health < lastHealth[player] then
                if Toggles.HitSound.Value then
                    HitSoundEffect.SoundId = HitSounds[Options.HitSoundSelector.Value]
                    HitSoundEffect.Volume = Options.HitSoundVolume.Value
                    HitSoundEffect:Play()
                end
            end
            lastHealth[player] = hum.Health
        end
    end

    for player, drawings in pairs(ESP) do
        local character = player.Character
        local humanoid = character and character:FindFirstChild('Humanoid')
        local rootPart = character and character:FindFirstChild('HumanoidRootPart')
        local isFriend = LocalPlayer:IsFriendsWith(player.UserId)
        local role, roleCol = GetRoleInfo(player)
        
        local skip = false
        if Toggles.IgnoreFriends.Value and isFriend then skip = true end
        if Toggles.IgnoreGuards.Value and role == "Guard" then skip = true end
        if Toggles.IgnoreInmates.Value and role == "Inmate" then skip = true end
        if Toggles.IgnoreCriminals.Value and role == "Criminal" then skip = true end
        if Toggles.IgnoreNeutral.Value and role == "Neutral" then skip = true end

        if not skip and rootPart and humanoid and humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
            if onScreen then
                local topPos = Camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 3, 0))
                local bottomPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.5, 0))
                local sizeY = math.abs(topPos.Y - bottomPos.Y)
                local sizeX = sizeY * 0.6
                drawings.Box.Visible = Toggles.EspToggle.Value
                drawings.Box.Size = Vector2.new(sizeX, sizeY)
                drawings.Box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2)
                drawings.Box.Color = Toggles.BoxRainbow.Value and rainbow or Options.EspColor.Value
                drawings.Name.Visible = Toggles.EspName.Value
                drawings.Name.Text = player.Name
                drawings.Name.Position = Vector2.new(pos.X, pos.Y - sizeY / 2 - 15)
                drawings.Name.Color = Toggles.NameRainbow.Value and rainbow or Options.NameColor.Value
                drawings.Health.Visible = Toggles.EspHealth.Value
                drawings.Health.Text = 'HP: ' .. math.floor(humanoid.Health)
                drawings.Health.Position = Vector2.new(pos.X, pos.Y + sizeY / 2 + 5)
                drawings.Health.Color = Toggles.HealthRainbow.Value and rainbow or Options.HealthColor.Value
                drawings.FriendLabel.Visible = Toggles.FriendEsp.Value and isFriend
                drawings.FriendLabel.Position = Vector2.new(pos.X, pos.Y - sizeY / 2 - 30)
                drawings.RoleLabel.Visible = Toggles.EspRoles.Value
                drawings.RoleLabel.Text = role
                drawings.RoleLabel.Color = roleCol
                drawings.RoleLabel.Position = Vector2.new(pos.X, pos.Y + sizeY / 2 + 20)
                if Toggles.ChamsToggle.Value then
                    drawings.Highlight.Parent = character
                    drawings.Highlight.Enabled = true
                    local cColor = Toggles.ChamsRainbow.Value and rainbow or Options.ChamsColor.Value
                    drawings.Highlight.FillColor = cColor
                    drawings.Highlight.OutlineColor = cColor
                else drawings.Highlight.Enabled = false end
            else for _, d in pairs(drawings) do if typeof(d) ~= "Instance" then d.Visible = false else d.Enabled = false end end end
        else for _, d in pairs(drawings) do if typeof(d) ~= "Instance" then d.Visible = false else d.Enabled = false end end end
    end
end)

