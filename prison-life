local function GetRoleInfo(player)
    local team = player.Team and player.Team.Name or "Neutral"
    if team == "Guards" then return "Guard", Color3.fromRGB(0, 150, 255)
    elseif team == "Inmates" then return "Inmate", Color3.fromRGB(255, 165, 0)
    elseif team == "Criminals" then return "Criminal", Color3.fromRGB(255, 0, 0)
    else return "Neutral", Color3.fromRGB(255, 255, 255) end
end

local function IsVisible(part, character)
    if not Toggles.WallCheck.Value then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local result = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000, params)
    return result and result.Instance:IsDescendantOf(character)
end

local function GetClosestPlayer()
    local target = nil
    local shortestDist = Options.FovRadius.Value
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local part = char and char:FindFirstChild(Options.AimPart.Value == "Head" and "Head" or "UpperTorso")
        if part and root and hum and hum.Health > 0 then
            local dist = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude) or 0
            if dist > Options.AimMaxDist.Value then continue end
            local role, _ = GetRoleInfo(player)
            local isFriend = LocalPlayer:IsFriendsWith(player.UserId)
            local skip = false
            if Toggles.AimIgnoreFriends.Value and isFriend then skip = true end
            if Toggles.AimIgnoreGuards.Value and role == "Guard" then skip = true end
            if Toggles.AimIgnoreInmates.Value and role == "Inmate" then skip = true end
            if Toggles.AimIgnoreCriminals.Value and role == "Criminal" then skip = true end
            if Toggles.AimIgnoreNeutral.Value and role == "Neutral" then skip = true end
            if not skip then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if mag < shortestDist and IsVisible(part, char) then
                        shortestDist = mag
                        target = part
                    end
                end
            end
        end
    end
    return target
end

