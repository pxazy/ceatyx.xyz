local lastHealth = {}
local processedKills = {}
local OriginalMaterials = {}
Toggles.PotatoMode:OnChanged(function()
    if Toggles.PotatoMode.Value then
        for _, v in ipairs(game:GetDescendants()) do
            if v:IsA("BasePart") then
                OriginalMaterials[v] = {Material = v.Material, Transparency = v.Transparency}
                if v.Transparency ~= 1 then v.Material = Enum.Material.SmoothPlastic end
            elseif v:IsA("Texture") or v:IsA("Decal") then
                OriginalMaterials[v] = {Transparency = v.Transparency}
                v.Transparency = 1
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
                OriginalMaterials[v] = {Enabled = v.Enabled}
                v.Enabled = false
            end
        end
    else
        for obj, data in pairs(OriginalMaterials) do
            if obj and obj.Parent then
                if data.Material then obj.Material = data.Material end
                if data.Transparency then obj.Transparency = data.Transparency end
                if data.Enabled ~= nil then obj.Enabled = data.Enabled end
            end
        end
        table.clear(OriginalMaterials)
    end
end)

RunService.RenderStepped:Connect(function()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FovCircle.Visible = Toggles.ShowFov.Value
    FovCircle.Radius = Options.FovRadius.Value
    FovCircle.Position = center
    FovCircle.Color = EvaluateColor(Options.FovMode.Value, Options.FovColor.Value, Options.FovColor2.Value, Options.FovSpeed.Value)

    if Toggles.AimEnabled.Value and Options.AimBind:GetState() then
        local target = GetClosestPlayer()
        if target then
            local aimSmoothness = Options.AimSmooth.Value
            local lookAt = CFrame.new(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, 1 / aimSmoothness)
            if Toggles.AutoShoot.Value then mouse1click() end
        end
    end

    if Toggles.WallTPEnabled.Value and LocalPlayer.Character then
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local rayParam = RaycastParams.new()
            rayParam.FilterType = Enum.RaycastFilterType.Exclude
            rayParam.FilterDescendantsInstances = {LocalPlayer.Character}
            local rayResult = workspace:Raycast(root.Position, root.CFrame.LookVector * 2, rayParam)
            if rayResult then
                local targetPos = rayResult.Position + (root.CFrame.LookVector * Options.WallTPDist.Value)
                root.CFrame = CFrame.new(targetPos, targetPos + root.CFrame.LookVector)
            end
        end
    end

    if Toggles.SelfChams.Value and LocalPlayer.Character then
        SelfHighlight.Parent = LocalPlayer.Character
        SelfHighlight.Enabled = true
        local sColor = EvaluateColor(Options.SelfMode.Value, Options.SelfColor.Value, Options.SelfColor2.Value, Options.SelfSpeed.Value)
        SelfHighlight.FillColor = sColor
        SelfHighlight.OutlineColor = sColor
    else
        SelfHighlight.Enabled = false
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum then
            if lastHealth[player] and hum.Health < lastHealth[player] then
                local isMyTarget = false
                local rayParam = RaycastParams.new()
                rayParam.FilterType = Enum.RaycastFilterType.Exclude
                rayParam.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
                local rayResult = workspace:Raycast(Camera.CFrame.Position, Camera.CFrame.LookVector * 5000, rayParam)
                if rayResult and rayResult.Instance:IsDescendantOf(char) then
                    isMyTarget = true
                end

                if isMyTarget then
                    if Toggles.HitSound.Value and hum.Health > 0 then
                        HitSoundEffect.SoundId = SoundAssets[Options.HitSoundSelector.Value]
                        HitSoundEffect.Volume = Options.HitSoundVolume.Value
                        HitSoundEffect:Play()
                        if Toggles.HitLog.Value then 
                            local dmg = math.floor(lastHealth[player] - hum.Health)
                            Library:Notify(string.format("Hit %s for %d | Health: %d", player.Name, dmg, math.floor(hum.Health)), 3) 
                        end
                    end
                    
                    if Toggles.KillSound.Value and hum.Health <= 0 and not processedKills[player] then
                        processedKills[player] = true
                        KillSoundEffect.SoundId = SoundAssets[Options.KillSoundSelector.Value]
                        KillSoundEffect.Volume = Options.KillSoundVolume.Value
                        KillSoundEffect:Play()
                    end
                end
            end
            
            if hum.Health > 0 then
                processedKills[player] = nil
            end
            
            lastHealth[player] = hum.Health
        end
    end

    local espCol = EvaluateColor(Options.EspMode.Value, Options.EspColor.Value, Options.EspColor2.Value, Options.EspSpeed.Value)
    local fillCol = EvaluateColor(Options.FillMode.Value, Options.FillColor.Value, Options.FillColor2.Value, Options.EspSpeed.Value)
    local nameCol = EvaluateColor(Options.NameMode.Value, Options.NameColor.Value, Options.NameColor2.Value, Options.NameSpeed.Value)
    local healthCol = EvaluateColor(Options.HealthMode.Value, Options.HealthColor.Value, Options.HealthColor2.Value, Options.HealthSpeed.Value)

    for player, drawings in pairs(ESP) do
        local character = player.Character
        local humanoid = character and character:FindFirstChild('Humanoid')
        local rootPart = character and character:FindFirstChild('HumanoidRootPart')
        if rootPart and humanoid and humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
            if onScreen then
                local topPos = Camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 3, 0))
                local bottomPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.5, 0))
                local sizeY = math.abs(topPos.Y - bottomPos.Y)
                local sizeX = sizeY * 0.6
                drawings.Box.Visible = Toggles.EspToggle.Value
                drawings.Box.Size = Vector2.new(sizeX, sizeY)
                drawings.Box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2)
                drawings.Box.Color = espCol
                drawings.Box.Thickness = Options.BoxThickness.Value
                drawings.BoxFill.Visible = Toggles.BoxFill.Value and Toggles.EspToggle.Value
                if drawings.BoxFill.Visible then
                    drawings.BoxFill.Size = drawings.Box.Size
                    drawings.BoxFill.Position = drawings.Box.Position
                    drawings.BoxFill.Color = fillCol
                    drawings.BoxFill.Transparency = 1 - Options.BoxFillTrans.Value
                end
                drawings.Name.Visible = Toggles.EspName.Value
                drawings.Name.Text = player.Name
                drawings.Name.Position = Vector2.new(pos.X, pos.Y - sizeY / 2 - 15)
                drawings.Name.Color = nameCol
                drawings.Health.Visible = Toggles.EspHealth.Value
                drawings.Health.Text = 'HP: ' .. math.floor(humanoid.Health)
                drawings.Health.Position = Vector2.new(pos.X, pos.Y + sizeY / 2 + 5)
                drawings.Health.Color = healthCol
                
                local currentOffset = 18
                drawings.Role.Visible = Toggles.EspRole.Value
                local roleName, roleColor = GetRoleInfo(player)
                drawings.Role.Text = "[" .. roleName .. "]"
                drawings.Role.Position = Vector2.new(pos.X, pos.Y + sizeY / 2 + currentOffset)
                drawings.Role.Color = Toggles.EspRoleColor.Value and roleColor or Color3.new(1, 1, 1)
                
                if Toggles.EspRole.Value then currentOffset = currentOffset + 13 end
                
                local isFriend = LocalPlayer:IsFriendsWith(player.UserId)
                drawings.Friend.Visible = Toggles.EspFriend.Value and isFriend
                if drawings.Friend.Visible then
                    drawings.Friend.Text = "Friend"
                    drawings.Friend.Position = Vector2.new(pos.X, pos.Y + sizeY / 2 + currentOffset)
                    drawings.Friend.Color = Color3.fromRGB(0, 255, 0)
                end

                if Toggles.ChamsToggle.Value then
                    drawings.Highlight.Parent = character
                    drawings.Highlight.Enabled = true
                    local chamsCol = EvaluateColor(Options.ChamsMode.Value, Options.ChamsColor.Value, Options.ChamsColor2.Value, Options.ChamsSpeed.Value)
                    drawings.Highlight.FillColor = chamsCol
                    drawings.Highlight.OutlineColor = chamsCol
                else drawings.Highlight.Enabled = false end
            else for _, d in pairs(drawings) do if typeof(d) ~= "Instance" then d.Visible = false else d.Enabled = false end end end
        else for _, d in pairs(drawings) do if typeof(d) ~= "Instance" then d.Visible = false else d.Enabled = false end end end
    end
end)

